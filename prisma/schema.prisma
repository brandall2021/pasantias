generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────

enum Role {
  ESTUDIANTE
  EMPRESA
  UNIVERSIDAD
  TUTOR_EMPRESA
  TUTOR_ACADEMICO
  ADMIN
}

enum EmpresaEstado {
  PENDIENTE
  VALIDADA
  RECHAZADA
}

enum EstadoPasantia {
  BORRADOR
  PUBLICADA
  SELECCION
  ESPERA_CONVENIO
  ACTIVA
  FINALIZADA
  CANCELADA
}

enum PostulacionEstado {
  PENDIENTE
  REVISADO
  ACEPTADO
  RECHAZADO
}

enum ConvenioEstado {
  PENDIENTE
  COMPLETADO
}

enum EvaluacionTipo {
  EMPRESA_A_ALUMNO
  ALUMNO_A_EMPRESA
  TUTOR
}

enum TipoDocumento {
  CV
  DNI
  ANALITICO
  ALUMNO_REGULAR
  CONVENIO
  SEGURO
}

// ─── Empresa ──────────────────────────────────────────

model Empresa {
  id        String        @id @default(cuid())
  nombre    String
  cuit      String        @unique
  direccion String?
  telefono  String?
  email     String?
  sitioWeb  String?
  logo      String?
  estado    EmpresaEstado @default(PENDIENTE)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  usuarios  User[]
  pasantias Pasantia[]
}

// ─── Universidad / Estructura Académica ───────────────

model Universidad {
  id         String     @id @default(cuid())
  nombre     String     @unique
  direccion  String?
  telefono   String?
  email      String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  facultades Facultad[]
  usuarios   User[]
}

model Facultad {
  id           String     @id @default(cuid())
  nombre       String
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  universidadId String
  universidad   Universidad @relation(fields: [universidadId], references: [id], onDelete: Cascade)

  carreras      Carrera[]
  pasantiasNotificadas Pasantia[] @relation("UnidadAcademica")
}

model Carrera {
  id         String   @id @default(cuid())
  nombre     String
  createdAt  DateTime @default(now())

  facultadId String
  facultad   Facultad @relation(fields: [facultadId], references: [id], onDelete: Cascade)

  alumnos    User[]
}

// ─── Usuario ──────────────────────────────────────────

model User {
  id             String   @id @default(cuid())
  name           String
  email          String   @unique
  password       String?
  phone          String?
  image          String?
  role           Role     @default(ESTUDIANTE)
  verified       Boolean  @default(false)
  baneado        Boolean  @default(false)
  motivoBaneo    String?
  dni            String?
  fechaNacimiento DateTime?
  direccion      String?
  legajo         String?
  anioCursada    String?
  promedio       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  empresaId     String?
  empresa       Empresa?      @relation(fields: [empresaId], references: [id])
  universidadId String?
  universidad   Universidad?  @relation(fields: [universidadId], references: [id])
  carreraId     String?
  carrera       Carrera?      @relation(fields: [carreraId], references: [id])

  postulaciones Postulacion[]
  documentos    Documento[]
  auditoria     AuditLog[]
  mensajes      Mensaje[]
  evaluaciones  Evaluacion[]
  seguimientos  Seguimiento[]
}

// ─── Pasantía ─────────────────────────────────────────

model Pasantia {
  id            String         @id @default(cuid())
  titulo        String
  descripcion   String
  requisitos    String?
  area          String
  modalidad     String         @default("PRESENCIAL")
  duracion      String?
  becaEconomica String?
  cargaHoraria  String?
  vacantes      Int            @default(1)
  estado        EstadoPasantia @default(BORRADOR)
  activo        Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  empresaId       String
  empresa         Empresa     @relation(fields: [empresaId], references: [id])

  unidadAcademicaId String?
  unidadAcademica   Facultad? @relation("UnidadAcademica", fields: [unidadAcademicaId], references: [id])

  postulaciones  Postulacion[]
}

// ─── Postulación ──────────────────────────────────────

model Postulacion {
  id      String             @id @default(cuid())
  fecha   DateTime           @default(now())
  estado  PostulacionEstado  @default(PENDIENTE)
  mensaje String?

  alumnoId   String
  alumno     User     @relation(fields: [alumnoId], references: [id], onDelete: Cascade)

  pasantiaId String
  pasantia   Pasantia @relation(fields: [pasantiaId], references: [id], onDelete: Cascade)

  convenio      Convenio?
  conversacion  Conversacion?
  documentos    Documento[]

  @@unique([pasantiaId, alumnoId])
}

// ─── Convenio Tripartito ──────────────────────────────

model Convenio {
  id               String         @id @default(cuid())
  estado           ConvenioEstado @default(PENDIENTE)
  firmaAlumno      Boolean        @default(false)
  firmaEmpresa     Boolean        @default(false)
  firmaUniversidad Boolean        @default(false)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  postulacionId String      @unique
  postulacion   Postulacion @relation(fields: [postulacionId], references: [id], onDelete: Cascade)

  seguimientos Seguimiento[]
  evaluaciones Evaluacion[]
}

// ─── Conversación (Chat por postulación) ──────────────

model Conversacion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postulacionId String      @unique
  postulacion   Postulacion @relation(fields: [postulacionId], references: [id], onDelete: Cascade)

  mensajes Mensaje[]
}

model Mensaje {
  id      String   @id @default(cuid())
  texto   String
  fecha   DateTime @default(now())

  conversacionId String
  conversacion   Conversacion @relation(fields: [conversacionId], references: [id], onDelete: Cascade)

  autorId String
  autor   User     @relation(fields: [autorId], references: [id])
}

// ─── Documentos ───────────────────────────────────────

model Documento {
  id         String        @id @default(cuid())
  tipo       TipoDocumento
  url        String
  verificado Boolean       @default(false)
  createdAt  DateTime      @default(now())

  usuarioId      String
  usuario        User          @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  postulacionId  String?
  postulacion    Postulacion?  @relation(fields: [postulacionId], references: [id])
}

// ─── Seguimiento (bitácora del convenio) ──────────────

model Seguimiento {
  id          String   @id @default(cuid())
  descripcion String
  fecha       DateTime @default(now())

  convenioId String
  convenio   Convenio @relation(fields: [convenioId], references: [id], onDelete: Cascade)

  usuarioId String
  usuario   User     @relation(fields: [usuarioId], references: [id])
}

// ─── Evaluaciones ─────────────────────────────────────

model Evaluacion {
  id        String           @id @default(cuid())
  tipo      EvaluacionTipo
  puntaje   Int
  comentario String?
  fecha     DateTime         @default(now())

  convenioId String
  convenio   Convenio @relation(fields: [convenioId], references: [id], onDelete: Cascade)

  autorId String
  autor   User     @relation(fields: [autorId], references: [id])
}

// ─── Auditoría ────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  accion     String
  tabla      String?
  registroId String?
  detalle    String?
  ip         String?
  fecha      DateTime @default(now())

  usuarioId String
  usuario   User     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId])
  @@index([accion])
  @@index([tabla])
  @@index([fecha])
}
